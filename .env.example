# byteSquad frontend — environment variables
# Copy this file to `.env.local` and fill in real values.

# Public site URL — used for canonical URLs, sitemap, OpenGraph, JSON-LD.
NEXT_PUBLIC_SITE_URL=https://www.bytesquad.in

# ---- Contact form email (OPTIONAL) ----
# The /api/contact route sends an email ONLY if ALL of these are set.
# If they are missing, submissions are just logged to the server console
# (so the form works out-of-the-box in development).
# Easiest option — Brevo SMTP (https://app.brevo.com/settings/keys/smtp):
#   SMTP_HOST=smtp-relay.brevo.com
#   SMTP_PORT=587
#   SMTP_USER=<your Brevo login email>
#   SMTP_PASS=<your Brevo SMTP key>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Inbox that should receive contact enquiries:
CONTACT_TO=info@bytesquad.in
